#!/usr/bin/gawk -f

BEGIN {
    ARGB = 1
    while (1) {
	if (ARGV[ARGB] ~ /^(--(help|man|usage)|-[Hh?])$/) {
	    print "Rotates field columns and rows clockwise (counter-clockwise with --reverse)"
	    print "by 90 degrees."
	    print ""
	    print "Usage: fieldrot90 [-F|--field-separator FS] [-s|--output-separator OS] [--reverse] FILE [...] [-?|-H|--man|--usage]"
	    print "Usage: cat FILE [...] | fieldrot90 [-F|--field-separator FS] [-s|--output-separator OS] [--reverse]"
	    isHelp = 1
	    exit
	} else if (ARGV[1] == "--reverse") {
	    isReverse = 1
	    delete ARGV[1]
	} else if (ARGV[ARGB] == "--output-separator" || ARGV[ARGB] == "-s") {
	    delete ARGV[ARGB++]
	    outputSeparator = ARGV[ARGB]
	    delete ARGV[ARGB++]
	} else {
	    break
	}
    }
}
NR == 1 {
    # Use passed OS, fall back to FS unless it is a regular expression.
    if (outputSeparator != "") {
	OFS = outputSeparator
    } else {
	firstFieldAndSep = $1 FS
	if (NF == 0 || $0 == $1 || substr($0, 1, length(FS)) == FS || substr($0, 1, length(firstFieldAndSep)) == firstFieldAndSep) {
	    OFS = FS
	} else if (FS == " ") {
	    OFS = (($0 ~ /^\t/ || substr($0, 1, length(firstFieldAndSep)) == $1 "\t") ? "\t" : " ")
	} else {
	    print "Note: Using space as default output field separator; change via -s|--output-separator OS or pass a non-regular expression -F|--field-separator FS." > "/dev/stderr"
	}
    }
    isJoinRunsOfWhitespace = (FS == " " && outputSeparator == "")
}
{
    line[NR][0] = ""
    fieldNum[NR] = split($0, line[NR])
    maxN = (fieldNum[NR] > maxN ? fieldNum[NR] : maxN)
}
END {
    if (isHelp) exit

    # i turns original columns into fields
    # j turns original lines into characters
    if (isReverse) {
	for (i = maxN; i > 0; --i) {
	    rotatedLine = ""
	    sep = ""
	    for (j = 1; j <= NR; ++j) {
		rotatedLine = rotatedLine (fieldNum[j] >= i ? sep line[j][i] : (isJoinRunsOfWhitespace ? "" : sep))
		sep = OFS

		isOnlyEmptyFollow = 1
		for (z = j + 1; z <= NR; ++z) {
		    if (line[z][i] != "") {
			isOnlyEmptyFollow = 0
			break
		    }
		}
		if (isOnlyEmptyFollow) {
		    break
		}
	    }
	    print rotatedLine
	}
    } else {
	for (i = 1; i <= maxN; ++i) {
	    rotatedLine = ""
	    sep = ""
	    for (j = NR; j > 0; --j) {
		rotatedLine = rotatedLine (fieldNum[j] >= i ? sep line[j][i] : (isJoinRunsOfWhitespace ? "" : sep))
		sep = OFS

		isOnlyEmptyFollow = 1
		for (z = j - 1; z > 0; --z) {
		    if (line[z][i] != "") {
			isOnlyEmptyFollow = 0
			break
		    }
		}
		if (isOnlyEmptyFollow) {
		    break
		}
	    }
	    print rotatedLine
	}
    }
}
