#!/bin/bash
shopt -qs extglob

: ${FIELD_INPUTFILES_END=;}

printUsage()
{
    cat <<HELPTEXT
Print selected field(s) N (-N counted from behind, N... including all following,
-N... including all preceding) from stdin, separated by SEP (or the passed OS,
or the original FS).
HELPTEXT
    echo
    printf 'Usage: cat FILE [...] | %q %s\n' "$(basename "$1")" '[-F|--field-separator FS] [-s|--output-separator OS] [-u|--unbuffered] [-]N[...]|SEP [...]'
    printf 'Usage: %q %s\n' "$(basename "$1")" "... -i|--input FILE [-i ...]|--input-files FILE [...] ${FIELD_INPUTFILES_END} [-]N[...]|SEP [...] [-?|-h|--help]"
    echo
    cat <<HELPTEXT
Print everything but passed field(s) N (-N counted from behind) from stdin.
HELPTEXT
    echo
    printf 'Usage: cat FILE [...] | %q %s\n' "$(basename "$1")" '[-F|--field-separator FS] [-s|--output-separator OS] [-u|--unbuffered] -v|--remove [-]N [...]'
    printf 'Usage: %q %s\n' "$(basename "$1")" "... -i|--input FILE [-i ...]|--input-files FILE [...] ${FIELD_INPUTFILES_END} -v|--remove [-]N [...] [-?|-h|--help]"
}
fieldNumberError()
{
    echo >&2 'ERROR: No field number N passed.'
    echo >&2
    printUsage "$0" >&2
    exit 2
}

isBuffered=t
typeset -a fsArgs=()
outputSeparator=
typeset -a inputFilespecs=()
isRemoveFields=
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printUsage "$0"; exit 0;;
	--input|-i)	shift; inputFilespecs+=("${1:?}"); shift;;
	--input-files)	shift
			while [ $# -gt 0 -a "$1" != "$FIELD_INPUTFILES_END" ]
			do
			    inputFilespecs+=("$1")
			    shift
			done
			if [ $# -eq 0 ]; then
			    echo "ERROR: --input-files must be concluded with '${FIELD_INPUTFILES_END}'"; echo; printUsage "$0"
			    exit 2
			fi >&2
			shift
			if [ ${#inputFilespecs[@]} -eq 0 ]; then
			    echo 'ERROR: --input-files must be followed by at least one FILE.'; echo; printUsage "$0"
			    exit 2
			fi >&2
			;;
	--remove|-v)	shift; isRemoveFields=t;;
	--field-separator|-F)
			shift; fsArgs=(-F "$1"); shift;;
	--output-separator|-s)
			shift; outputSeparator="${1?}"; shift;;
	--unbuffered|-u)
			shift; isBuffered=;;
	--)		shift; break;;
	-+([0-9])?(...))
			break;;
	-*)		{ echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2;;
	*)		break;;
    esac
done
[ $# -gt 0 ] || fieldNumberError

outputSeparatorDetermination='
NR == 1 {
    # Use passed OS, fall back to FS unless it is a regular expression.
    if (outputSeparator != "") {
	OFS = outputSeparator
    } else {
	firstFieldAndSep = $1 FS
	if (NF == 0 || $0 == $1 || substr($0, 1, length(FS)) == FS || substr($0, 1, length(firstFieldAndSep)) == firstFieldAndSep) {
	    OFS = FS
	} else if (FS == " ") {
	    OFS = (($0 ~ /^\t/ || substr($0, 1, length(firstFieldAndSep)) == $1 "\t") ? "\t" : " ")
	} else {
	    print "Note: Using space as default output field separator; change via -s|--output-separator OS or pass a non-regular expression -F|--field-separator FS." > "/dev/stderr"
	}
    }
}
'

if [ "$isRemoveFields" ]; then
    exec awk "${fsArgs[@]}" \
	-v "outputSeparator=${outputSeparator//\\/\\\\}" \
	-v "isBuffered=$isBuffered" \
	-v nrs="$*" '
BEGIN {
    split(nrs, numbers, " ")
    for (n in numbers) {
	if (numbers[n] !~ /^-?[[:digit:]]+$/) {
	    print "ERROR: Not a number: " numbers[n] > "/dev/stderr"
	    exit 2
	}

	if (numbers[n] >= 0) {
	    fields[numbers[n]] = 1
	} else {
	    negfields[-1 * numbers[n] - 1] = 1
	}
    }
}
'"$outputSeparatorDetermination"'
{
    isFirst = 1
    for (i = 1; i <= NF; i++) {
	if (! (i in fields || (NF - i) in negfields)) {
	    printf "%s%s", (isFirst ? "" : OFS), $i
	    isFirst = 0
	}
    }
    printf "%s", ORS
    if (! isBuffered) fflush()
}
' "${inputFilespecs[@]}"
else
    handleDelayed()
    {
	[ -n "$delayedPrecedingFieldNr" ] || return
	selectors+=" precedingFieldsFromEnd($delayedPrecedingFieldNr, $separator)"
	delayedPrecedingFieldNr=
    }
    isSubsequent=
    separator='OFS'
    selectors=
    for arg
    do
	case $arg in
	    +([0-9]))   handleDelayed
			selectors+=" ${isSubsequent:+$separator }\$$arg"
			separator='OFS'
			;;
	    +([0-9])...)
			handleDelayed
			selectors+=" ${isSubsequent:+$separator }followingFields(${arg%...}, $separator)"
			separator='OFS'
			;;
	    -+([0-9]))  handleDelayed
			selectors+=" ${isSubsequent:+$separator }fieldFromEnd(${arg#-})"
			separator='OFS'
			;;
	    -+([0-9])...)
			handleDelayed
			arg="${arg#-}"; arg="${arg%...}"
			delayedPrecedingFieldNr=$arg
			;;
	    *)		arg="${arg//\\/\\\\}"
			arg="${arg//\"/\\\"}"
			arg="${arg//$'\n'/\\\n}"
			separator="\"${arg}\""
			;;
	esac
	isSubsequent=t
    done
    handleDelayed
    [ -n "$selectors" ] || fieldNumberError

    exec awk "${fsArgs[@]}" \
	-v "outputSeparator=${outputSeparator//\\/\\\\}" \
	-v "isBuffered=$isBuffered" \
'
function followingFields(n, separator,      result, i)
{
    result = ""
    for (i = n; i <= NF; ++i) {
	result = result (result == "" ? "" : separator) $i
    }
    return result
}
function fieldFromEnd(n)
{
    return (n < NF ? $(NF - n + 1) : "")
}
function precedingFieldsFromEnd(n, separator,      result, i)
{
    result = ""
    for (i = 1; i <= (NF - n + 1); ++i) {
	result = result (result == "" ? "" : separator) $i
    }
    return result
}
'"
$outputSeparatorDetermination
{
    print$selectors
    if (! isBuffered) fflush()
}" "${inputFilespecs[@]}"
fi
